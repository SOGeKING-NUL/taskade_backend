# Sarvam AI (STT + TTS)
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Gemini (LLM)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# TTS Settings
SARVAM_TTS_VOICE=anushka
SARVAM_TTS_LANGUAGE=en-IN
SARVAM_TTS_MODEL=bulbul:v2
SARVAM_TTS_SAMPLE_RATE=22050

# STT Settings
SARVAM_STT_LANGUAGE=en-IN
SARVAM_STT_MODEL=saaras:v3

# LLM persona (shared by the fast SLM and the tool-calling LLM)
LLM_SYSTEM_PROMPT=You are a helpful, friendly AI assistant. Keep responses concise and conversational — aim for 1-3 sentences unless the user asks for detail.

# Groq — fast SLM path (answers ordinary turns, escalates for actions)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
SLM_MODEL=llama-3.1-8b-instant

# OpenRouter — tool-calling / research LLM (no Gemini credits needed)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Pick a cheap, capable tool-calling model from https://openrouter.ai/models
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=http://localhost:5173
